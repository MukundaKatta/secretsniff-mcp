  "version": "0.1.0",
  "repository": {
    "url": "https://github.com/MukundaKatta/secretsniff-mcp",
    "source": "github"
  },
  "websiteUrl": "https://github.com/MukundaKatta/secretsniff-mcp",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@mukundakatta/secretsniff-mcp",
      "version": "0.1.0",
      "transport": {
        "type": "stdio"
      }
    }
  ]
}
